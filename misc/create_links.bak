systemctl stop container
systemctl stop docker.socket
systemctl stop docker
cd /usr/bin && ln -sf /Home1/docker/bin/containerd . && ln -sf /Home1/docker/bin/containerd-shim-runc-v2 . && ln -sf /Home1/docker/bin/docker . && ln -sf /Home1/docker/bin/docker-compose . && ln -sf /Home1/docker/bin/dockerd . && cp -a /Home1/docker/bin/dockerd-rootless* /Home1/docker/bin/docker-proxy /Home1/docker/bin/rootlesskit .

rm /usr/bin/pip && ln -sf /opt/venv/bin/pip /usr/bin/pip

systemctl restart containerd
systemctl restart docker.socket
systemctl restart docker

cp -a /home/mongodb/group /home/mongodb/passwd /etc && ln -sf /home/mongodb/mongod.conf /etc/mongod.conf && ln -sf /home/mongodb/mongod /usr/bin/mongod

