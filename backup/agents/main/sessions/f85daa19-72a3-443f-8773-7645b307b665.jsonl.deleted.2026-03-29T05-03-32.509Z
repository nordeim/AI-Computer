{"type":"message","id":"7e39ceb3","parentId":"b1455d30","timestamp":"2026-03-03T04:52:35.883Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":" Good, context directory created. Now I'll create the enhanced anchor.sh with QMD integration, then the unified","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"          functions.exec:96","name":"exec","arguments":{"command":"cp /home/pete/.openclaw/workspace/skills/context-anchor/scripts/anchor.sh /home/pete/.openclaw/workspace/skills/context-anchor/scripts/anchor.sh.backup.$(date +%Y%m%d_%H%M%S)","description":"Backup original anchor.sh"}},{"type":"toolCall","id":"          functions.write:97","name":"write","arguments":{"path":"/home/pete/.openclaw/workspace/skills/context-anchor/scripts/anchor.sh","content":"#!/bin/bash\n#\n# context-anchor: Recover context after compaction\n# Scans memory files and generates a \"here's where you are\" briefing\n# Updated: Supports both QMD hierarchical (daily/YYYY/MM/DD.md) and flat (YYYY-MM-DD.md) structures\n# NEW: QMD semantic integration — enhanced context recovery\n#\n# Usage:\n#   anchor.sh                      # Full briefing (default)\n#   anchor.sh --quick              # Fast recovery, skip QMD\n#   anchor.sh --semantic           # Include QMD semantic expansion\n#   anchor.sh --semantic N         # QMD depth N (default: 3)\n#   anchor.sh --decisions          # Only decisions\n#   anchor.sh --loops                # Only open loops\n#   anchor.sh --days 3             # Scan 3 days back\n#\n# Integration:\n#   - context-recover.sh (unified entry point)\n#   - QMD for semantic similarity\n\nset -e\n\n# Configuration\nWORKSPACE=\"${WORKSPACE:-$(cd \"$(dirname \"$0\")/../../..\" && pwd)}\"\nMEMORY_DIR=\"$WORKSPACE/memory\"\nCONTEXT_DIR=\"$WORKSPACE/context/active\"\nDAYS_BACK=\"${DAYS_BACK:-2}\"\n\n# QMD Integration Settings\nUSE_SEMANTIC=false\nSEMANTIC_DEPTH=3\nQUICK_MODE=false\n\n# Colors (disabled if not a terminal)\nif [ -t 1 ]; then\n    BOLD='\\033[1m'\n    DIM='\\033[2m'\n    RESET='\\033[0m'\n    BLUE='\\033[34m'\n    GREEN='\\033[32m'\n    YELLOW='\\033[33m'\n    CYAN='\\033[36m'\n    MAGENTA='\\033[35m'\nelse\n    BOLD='' DIM='' RESET='' BLUE='' GREEN='' YELLOW='' CYAN='' MAGENTA=''\nfi\n\n# Parse arguments\nSHOW_ALL=true\nSHOW_TASK=false\nSHOW_ACTIVE=false\nSHOW_DECISIONS=false\nSHOW_LOOPS=false\n\nwhile [[ $# -gt 0 ]]; do\n    case $1 in\n        --quick)\n            QUICK_MODE=true\n            shift\n            ;;\n        --semantic)\n            USE_SEMANTIC=true\n            if [[ \"$2\" =~ ^[0-9]+$ ]]; then\n                SEMANTIC_DEPTH=\"$2\"\n                shift 2\n            else\n                shift\n            fi\n            ;;\n        --task)\n            SHOW_ALL=false; SHOW_TASK=true; shift\n            ;;\n        --active)\n            SHOW_ALL=false; SHOW_ACTIVE=true; shift\n            ;;\n        --decisions)\n            SHOW_ALL=false; SHOW_DECISIONS=true; shift\n            ;;\n        --loops)\n            SHOW_ALL=false; SHOW_LOOPS=true; shift\n            ;;\n        --days)\n            DAYS_BACK=\"$2\"; shift 2\n            ;;\n        --help|-h)\n            cat << 'EOF'\nUsage: anchor.sh [OPTIONS]\n\nOptions:\n  --quick              Skip QMD semantic expansion (fast mode)\n  --semantic [N]       Include QMD semantic expansion (depth N, default: 3)\n  --task               Show only current task\n  --active             Show only active context files\n  --decisions          Show only recent decisions\n  --loops              Show only open loops\n  --days N             Scan N days back (default: 2)\n  --help               Show this help\n\nExamples:\n  anchor.sh --semantic 5     # Full briefing with 5 QMD results per topic\n  anchor.sh --quick        # Fast baseline briefing (no QMD)\n  anchor.sh --decisions    # Only show decisions\n\nIntegration:\n  Called by context-recover.sh (unified entry point)\nEOF\n            exit 0\n            ;;\n        *)\n            echo \"Unknown option: $1\"\n            exit 1\n            ;;\n    esac\ndone\n\n# Helper: print header\nheader() {\n    echo -e \"${BOLD}${BLUE}$1${RESET}\"\n    echo -e \"${DIM}───────────────────────────────────────────────────────────${RESET}\"\n}\n\n# Helper: relative time\nrelative_time() {\n    local file=\"$1\"\n    local now=$(date +%s)\n    local mod\n    # macOS vs Linux stat\n    if [[ \"$OSTYPE\" == \"darwin\"* ]]; then\n        mod=$(stat -f %m \"$file\" 2>/dev/null || echo 0)\n    else\n        mod=$(stat -c %Y \"$file\" 2>/dev/null || echo 0)\n    fi\n    local diff=$((now - mod))\n    if [ $diff -lt 60 ]; then echo \"just now\"\n    elif [ $diff -lt 3600 ]; then echo \"$((diff / 60))m ago\"\n    elif [ $diff -lt 86400 ]; then echo \"$((diff / 3600))h ago\"\n    else echo \"$((diff / 86400))d ago\"\n    fi\n}\n\n# Helper: format date from filename\nextract_date_from_path() {\n    local filepath=\"$1\"\n    local filename=$(basename \"$filepath\" .md)\n    if [[ \"$filepath\" =~ /daily/([0-9]{4})/([0-9]{2})/([0-9]{2})\\.md$ ]]; then\n        echo \"${BASH_REMATCH[1]}-${BASH_REMATCH[2]}-${BASH_REMATCH[3]}\"\n    elif [[ \"$filename\" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then\n        echo \"$filename\"\n    else\n        echo \"$filename\"\n    fi\n}\n\n# Helper: check if QMD available\nqmd_available() {\n    command -v qmd >/dev/null 2>&1\n}\n\n# Helper: QMD semantic expansion\nsemantic_expand() {\n    local topic=\"$1\"\n    local depth=\"${2:-3}\"\n    local collection=\"${3:-daily}\"\n    \n    if ! qmd_available || [ \"$QUICK_MODE\" = true ]; then\n        return 0\n    fi\n    \n    # Suppress verbose output, only get useful lines\n    qmd query \"$topic\" -c \"$collection\" --limit \"$depth\" 2>/dev/null | \\\n        grep -v \"^Warning:\" | \\\n        grep -v \"^\\[\" | \\\n        head -$((depth * 3)) | \\\n        grep -E \"[a-zA-Z]\" || true\n}\n\n# Helper: get daily files for last N days\nget_daily_files() {\n    local files=()\n    local seen_dates=()\n    for i in $(seq 0 $((DAYS_BACK - 1))); do\n        if [[ \"$OSTYPE\" == \"darwin\"* ]]; then\n            local date_str=$(date -v-${i}d +%Y-%m-%d)\n            local year=$(date -v-${i}d +%Y)\n            local month=$(date -v-${i}d +%m)\n            local day=$(date -v-${i}d +%d)\n        else\n            local date_str=$(date -d \"-$i days\" +%Y-%m-%d)\n            local year=$(date -d \"-$i days\" +%Y)\n            local month=$(date -d \"-$i days\" +%m)\n            local day=$(date -d \"-$i days\" +%d)\n        fi\n        \n        if [[ \" ${seen_dates[@]} \" =~ \" ${date_str} \" ]]; then continue; fi\n        seen_dates+=(\"$date_str\")\n        \n        local qmd_file=\"$MEMORY_DIR/daily/$year/$month/$day.md\"\n        if [ -f \"$qmd_file\" ]; then\n            files+=(\"$qmd_file\")\n            continue\n        fi\n        \n        local flat_file=\"$MEMORY_DIR/${date_str}.md\"\n        if [ -f \"$flat_file\" ]; then\n            files+=(\"$flat_file\")\n        fi\n    done\n    echo \"${files[@]}\"\n}\n\n# Section: Current Task\nshow_current_task() {\n    header \"📋 CURRENT TASK\"\n    local task_file=\"$MEMORY_DIR/current-task.md\"\n    if [ -f \"$task_file\" ]; then\n        echo -e \"${DIM}($(relative_time \"$task_file\"))${RESET}\"\n        echo \"\"\n        cat \"$task_file\"\n        \n        # QMD expansion for task\n        if [ \"$USE_SEMANTIC\" = true ]; then\n            echo \"\"\n            echo -e \"${DIM}Related via QMD:${RESET}\"\n            local task_preview=$(head -5 \"$task_file\")\n            semantic_expand \"$task_preview\" 2 | head -2 | sed 's/^/ └─ /' | sed \"s/^/${DIM}/;s/$/${RESET}/\" || true\n        fi\n    else\n        echo -e \"${DIM}No current task set${RESET}\"\n    fi\n    echo \"\"\n}\n\n# Section: Active Context Files\nshow_active_context() {\n    header \"📂 ACTIVE CONTEXT FILES\"\n    if [ ! -d \"$CONTEXT_DIR\" ]; then\n        echo -e \"${DIM}No context/active/ directory${RESET}\"\n        echo \"\"\n        return\n    fi\n    \n    local found=false\n    for file in \"$CONTEXT_DIR\"/*.md; do\n        [ -e \"$file\" ] || continue\n        found=true\n        local name=$(basename \"$file\")\n        local age=$(relative_time \"$file\")\n        local preview=$(head -n 5 \"$file\" | grep -v '^#' | grep -v '^$' | head -n 1)\n        echo -e \"${GREEN}• ${name}${RESET} ${DIM}(${age})${RESET}\"\n        if [ -n \"$preview\" ]; then\n            echo"}},{"type":"text","text":" -e \\\" ${DIM}└─ ${"}],"api":"openai-completions","provider":"nvidia","model":"moonshotai/kimi-k2.5","usage":{"input":66954,"output":4171,"cacheRead":0,"cacheWrite":0,"totalTokens":71125,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772513259002}}
