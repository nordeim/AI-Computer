{"type":"message","id":"988f3b55","parentId":"6effb096","timestamp":"2026-03-03T00:56:01.045Z","message":{"role":"toolResult","toolCallId":"           functions.read:36","toolName":"read","content":[{"type":"text","text":"#!/bin/bash\n# Generate Daily Ping Message File\n# This script reads the log and creates a formatted message file\n\nLOG_FILE=\"/home/project/openclaw/logs/daily-ping-$(date +%Y-%m-%d).log\"\nMESSAGE_FILE=\"/home/project/openclaw/daily-message.txt\"\n\n# Check if log exists\nif [ ! -f \"$LOG_FILE\" ]; then\n    echo \"Error: Log file not found\" >&2\n    exit 1\nfi\n\n# Extract Bitcoin data from log\nBTC_PRICE=$(grep -o '\"usd\":[0-9]*' \"$LOG_FILE\" | tail -1 | cut -d: -f2)\nBTC_CHANGE=$(grep -o '\"usd_24h_change\":[-0-9.]*' \"$LOG_FILE\" | tail -1 | cut -d: -f2)\n\n# Format change with trend indicator\nif (( $(echo \"$BTC_CHANGE > 0\" | bc -l 2>/dev/null || echo \"0\") )); then\n    BTC_TREND=\"📈\"\nelse\n    BTC_TREND=\"📉\"\nfi\n\n# Get stock data JSON from log and format\nSTOCK_SECTION=\"\"\nif grep -q '\"NVDA\"' \"$LOG_FILE\" 2>/dev/null; then\n    STOCK_SECTION=\"📊 Tech Stocks\\n\"\n    for symbol in NVDA MSFT GOOGL INTC META AMD; do\n        PRICE=$(grep -oP \"\\\"$symbol\\\":.*?\\\"price\\\":\\s*[0-9.]+\" \"$LOG_FILE\" | grep -o '[0-9.]*$' | head -1)\n        CHANGE=$(grep -oP \"\\\"$symbol\\\":.*?\\\"change_pct\\\":\\s*[-0-9.]+\" \"$LOG_FILE\" | grep -o '[-0-9.]*$' | head -1)\n        if [ -n \"$PRICE\" ] && [ -n \"$CHANGE\" ]; then\n            if (( $(echo \"$CHANGE >= 0\" | bc -l 2>/dev/null || echo \"0\") )); then\n                TREND=\"📈\"\n            else\n                TREND=\"📉\"\n            fi\n            # Format change with + sign if positive\n            if (( $(echo \"$CHANGE >= 0\" | bc -l 2>/dev/null || echo \"0\") )); then\n                CHANGE_FMT=\"+$(printf \"%.2f\" $CHANGE)%%\"\n            else\n                CHANGE_FMT=\"$(printf \"%.2f\" $CHANGE)%%\"\n            fi\n            STOCK_SECTION+=\"\\n• $symbol: \\$$PRICE ($CHANGE_FMT) $TREND\"\n        fi\n    done\nfi\n\n# Get GitHub trending repos from log\nGITHUB_SECTION=\"\"\nif grep -q '\"total_count\":' \"$LOG_FILE\" 2>/dev/null; then\n    GITHUB_SECTION=\"\\n\\n🚀 Trending GitHub Repos\\n\"\n    # Extract repo names and stars from the log - careful with the pattern\n    REPO_DATA=$(grep -o '\"full_name\":\"[^\"]*\"' \"$LOG_FILE\" | head -10)\n    STAR_DATA=$(grep -o '\"stargazers_count\":[0-9]*' \"$LOG_FILE\" | head -10)\n    \n    # Combine using paste\n    if [ -n \"$REPO_DATA\" ] && [ -n \"$STAR_DATA\" ]; then\n        i=1\n        while IFS= read -r repo_line && IFS= read -r star_line <&3; do\n            repo=$(echo \"$repo_line\" | sed 's/\"full_name\":\"//g; s/\"$//g')\n            stars=$(echo \"$star_line\" | sed 's/\"stargazers_count\"://g')\n            \n            # Format stars as K if >= 1000\n            if [ \"$stars\" -ge 1000 ] 2>/dev/null; then\n                stars_fmt=\"$(echo \"scale=1; $stars/1000\" | bc 2>/dev/null || echo \"$((stars/1000))\")K\"\n            else\n                stars_fmt=\"$stars\"\n            fi\n            \n            GITHUB_SECTION+=\"\\n$i. $repo ⭐ $stars_fmt\"\n            i=$((i+1))\n        done < <(echo \"$REPO_DATA\") 3< <(echo \"$STAR_DATA\")\n    fi\nfi\n\n# Create message\ncat > \"$MESSAGE_FILE\" << EOF\n📅 Daily Ping — $(date +\"%A, %B %d, %Y\")\n\n💰 Bitcoin\n• Price: \\$${BTC_PRICE:-N/A} USD\n• 24h: ${BTC_CHANGE:-N/A}% $BTC_TREND\n\n${STOCK_SECTION}${GITHUB_SECTION}\n\n—\n⏰ $(date +\"%H:%M %Z\")\nEOF\n\necho \"Message generated: $MESSAGE_FILE\"\n"}],"isError":false,"timestamp":1772499361040}}
