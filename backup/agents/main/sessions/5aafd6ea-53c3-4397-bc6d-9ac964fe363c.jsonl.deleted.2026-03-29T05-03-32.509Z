te  4096 Feb 10 10:46 linkedin-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 mailchimp-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 make-automation\ndrwxrwxr-x   4 pete pete  4096 Feb 10 10:46 mcp-builder\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 meeting-insights-analyzer\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 microsoft-teams-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 miro-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 mixpanel-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 monday-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 notion-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 one-drive-automation\ndrwxrwxr-x   2 pete pete  4096 Feb  3 09:49 opencode-orchestrator\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 outlook-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 outlook-calendar-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 pagerduty-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 pipedrive-automation\ndrwxrwxr-x   2 pete pete  4096 Feb  3 09:11 playwright-design-extractor\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 posthog-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 postmark-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 raffle-winner-picker\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 reddit-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 render-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 salesforce-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 segment-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 sendgrid-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 sentry-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 shopify-automation\ndrwxrwxr-x   3 pete pete  4096 Feb 10 10:46 skill-creator\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 skill-share\ndrwxrwxr-x   2 pete pete  4096 Feb  2 14:46 slack\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 slack-automation\ndrwxrwxr-x   4 pete pete  4096 Feb 10 10:46 slack-gif-creator\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 square-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 stripe-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 supabase-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 tailored-resume-generator\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 telegram-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 template-skill\ndrwxrwxr-x   3 pete pete  4096 Feb 10 10:46 theme-factory\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 tiktok-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 todoist-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 trello-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 twitter-algorithm-optimizer\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 twitter-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 vercel-automation\ndrwxrwxr-x   3 pete pete  4096 Feb 10 10:46 video-downloader\ndrwxrwxr-x   4 pete pete  4096 Feb 10 10:46 webapp-testing\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 webflow-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 whatsapp-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 wrike-automation\ndrwxrwxr-x   2 pete pete  4096 Feb  2 15:09 yahoo-finance\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 youtube-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 zendesk-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 zoho-crm-automation\ndrwxrwxr-x   2 pete pete  4096 Feb 10 10:46 zoom-automation","cwd":"/home/pete/.openclaw/workspace"},"isError":false,"timestamp":1770692096983}}
