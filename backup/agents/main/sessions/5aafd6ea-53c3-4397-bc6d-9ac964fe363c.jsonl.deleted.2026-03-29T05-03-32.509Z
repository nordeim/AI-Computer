nd workflow optimization\",\n      \"skills\": {\n        \"file-organizer\": {\"path\": \"file-organizer\", \"purpose\": \"Organize files, find duplicates, cleanup\"},\n        \"invoice-organizer\": {\"path\": \"invoice-organizer\", \"purpose\": \"Organize invoices/receipts for taxes\"},\n        \"raffle-winner-picker\": {\"path\": \"raffle-winner-picker\", \"purpose\": \"Secure random winner selection\"},\n        \"tailored-resume-generator\": {\"path\": \"tailored-resume-generator\", \"purpose\": \"Generate job-specific resumes\"},\n        \"domain-name-brainstormer\": {\"path\": \"domain-name-brainstormer\", \"purpose\": \"Generate domain name ideas\"}\n      }\n    },\n    \"communication_writing\": {\n      \"description\": \"Content creation and analysis\",\n      \"skills\": {\n        \"content-research-writer\": {\"path\": \"content-research-writer\", \"purpose\": \"Research-backed content writing\"},\n        \"meeting-insights-analyzer\": {\"path\": \"meeting-insights-analyzer\", \"purpose\": \"Analyze meeting transcripts\"}\n      }\n    },\n    \"meta_utility\": {\n      \"description\": \"Skill creation and app connection\",\n      \"skills\": {\n        \"skill-creator\": {\"path\": \"skill-creator\", \"purpose\": \"Create new Claude skills\"},\n        \"connect\": {\"path\": \"connect\", \"purpose\": \"Connect Claude to 1000+ apps via Composio\"},\n        \"connect-apps\": {\"path\": \"connect-apps\", \"purpose\": \"Setup plugin for app connections\"},\n        \"connect-apps-plugin\": {\"path\": \"connect-apps-plugin\", \"purpose\": \"Plugin directory for connect-apps\"},\n        \"template-skill\": {\"path\": \"template-skill\", \"purpose\": \"Template for creating new skills\"}\n      }\n    },\n    \"finance\": {\n      \"description\": \"Financial data and market analysis\",\n      \"skills\": {\n        \"yahoo-finance\": {\"path\": \"yahoo-finance\", \"purpose\": \"Fetch stock/financial data from Yahoo Finance\"}\n      }\n    },\n    \"messaging\": {\n      \"description\": \"Messaging platform integrations\",\n      \"skills\": {\n        \"slack\": {\"path\": \"slack\", \"purpose\": \"Slack integration\"}\n      }\n    }\n  },\n  \"skill_index\": {\n    \"activecampaign-automation\": {\"category\": \"app_automation\", \"subcategory\": \"email\"},\n    \"airtable-automation\": {\"category\": \"app_automation\", \"subcategory\": \"spreadsheets\"},\n    \"amplitude-automation\": {\"category\": \"app_automation\", \"subcategory\": \"analytics\"},\n    \"artifacts-builder\": {\"category\": \"development\", \"purpose\": \"React + Tailwind HTML artifacts\"},\n    \"asana-automation\": {\"category\": \"app_automation\", \"subcategory\": \"project_management\"},\n    \"bamboohr-automation\": {\"category\": \"app_automation\", \"subcategory\": \"hr\"},\n    \"basecamp-automation\": {\"category\": \"app_automation\", \"subcategory\": \"project_management\"},\n    \"bitbucket-automation\": {\"category\": \"app_automation\", \"subcategory\": \"devops\"},\n    \"box-automation\": {\"category\": \"app_automation\", \"subcategory\": \"storage\"},\n    \"brand-guidelines\": {\"category\": \"creative_media\", \"purpose\": \"Brand colors/typography\"},\n    \"brevo-automation\": {\"category\": \"app_automation\", \"subcategory\": \"email\"},\n    \"cal-com-automation\": {\"category\": \"app_automation\", \"subcategory\": \"calendar\"},\n    \"calendly-automation\": {\"category\": \"app_automation\", \"subcategory\": \"calendar\"},\n    \"canva-automation\": {\"category\": \"app_automation\", \"subcategory\": \"design_collab\"},\n    \"canvas-design\": {\"category\": \"creative_media\", \"purpose\": \"Visual art PNG/PDF\"},\n    \"changelog-generator\": {\"category\": \"development\", \"purpose\": \"Git to changelog\"},\n    \"chrome-devtools-mcp\": {\"category\": \"development\", \"purpose\": \"Chrome DevTools MCP\"},\n    \"circleci-automation\": {\"category\": \"app_automation\", \"subcategory\": \"devops\"},\n    \"clickup-automation\": {\"category\": \"app_automation\", \"subcategory\": \"project_management\"},\n    \"close-automation\": {\"category\": \"app_automation\", \"subcategory\": \"crm_sales\"},\n    \"coda-automation\": {\"category\": \"app_automation\", \"subcategory\": \"spreadsheets\"},\n    \"competitive-ads-extractor\": {\"category\": \"business_marketing\", \"purpose\": \"Competitor ad analysis\"},\n    \"composio-sdk\": {\"category\": \"development\", \"purpose\": \"Composio SDK\"},\n    \"confluence-automation\": {\"category\": \"app_automation\", \"subcategory\": \"design_collab\"},\n    \"connect\": {\"category\": \"meta_utility\", \"purpose\": \"Connect to 1000+ apps\"},\n    \"connect-apps\": {\"category\": \"meta_utility\", \"purpose\": \"App connection setup\"},\n    \"connect-apps-plugin\": {\"category\": \"meta_utility\", \"purpose\": \"Plugin directory\"},\n    \"content-research-writer\": {\"category\": \"communication_writing\", \"purpose\": \"Research-backed content\"},\n    \"convertkit-automation\": {\"category\": \"app_automation\", \"subcategory\": \"email\"},\n    \"datadog-automation\": {\"category\": \"app_automation\", \"subcategory\": \"devops\"},\n    \"developer-growth-analysis\": {\"category\": \"business_marketing\", \"purpose\": \"Developer metrics\"},\n    \"discord-automation\": {\"category\": \"app_automation\", \"subcategory\": \"communication\"},\n    \"document-skills\": {\"category\": \"development\", \"purpose\": \"Document processing\"},\n    \"docusign-automation\": {\"category\": \"app_automation\", \"subcategory\": \"design_collab\"},\n    \"domain-name-brainstormer\": {\"category\": \"productivity\", \"purpose\": \"Domain name ideas\"},\n    \"dropbox-automation\": {\"category\": \"app_automation\", \"subcategory\": \"storage\"},\n    \"figma-automation\": {\"category\": \"app_automation\", \"subcategory\": \"design_collab\"},\n    \"file-organizer\": {\"category\": \"productivity\", \"purpose\": \"File organization\"},\n    \"freshdesk-automation\": {\"category\": \"app_automation\", \"subcategory\": \"support\"},\n    \"freshservice-automation\": {\"category\": \"app_automation\", \"subcategory\": \"support\"},\n    \"github-automation\": {\"category\": \"app_automation\", \"subcategory\": \"devops\"},\n    \"gitlab-automation\": {\"category\": \"app_automation\", \"subcategory\": \"devops\"},\n    \"gmail-automation\": {\"category\": \"app_automation\", \"subcategory\": \"email\"},\n    \"google-analytics-automation\": {\"category\": \"app_automation\", \"subcategory\": \"analytics\"},\n    \"google-calendar-automation\": {\"category\": \"app_automation\", \"subcategory\": \"calendar\"},\n    \"google-drive-automation\": {\"category\": \"app_automation\", \"subcategory\": \"storage\"},\n    \"googlesheets-automation\": {\"category\": \"app_automation\", \"subcategory\": \"spreadsheets\"},\n    \"helpdesk-automation\": {\"category\": \"app_automation\", \"subcategory\": \"support\"},\n    \"hubspot-automation\": {\"category\": \"app_automation\", \"subcategory\": \"crm_sales\"},\n    \"image-enhancer\": {\"category\": \"creative_media\", \"purpose\": \"Image enhancement\"},\n    \"instagram-automation\": {\"category\": \"app_automation\", \"subcategory\": \"social_media\"},\n    \"intercom-automation\": {\"category\": \"app_automation\", \"subcategory\": \"communication\"},\n    \"internal-comms\": {\"category\": \"business_marketing\", \"purpose\": \"Internal communications\"},\n    \"invoice-organizer\": {\"category\": \"productivity\", \"purpose\": \"Invoice organization\"},\n    \"jira-automation\": {\"category\": \"app_automation\", \"subcategory\": \"project_management\"},\n    \"klaviyo-automation\": {\"category\": \"app_automation\", \"subcategory\": \"email\"},\n    \"langsmith-fetch\": {\"category\": \"development\", \"purpose\": \"LangChain debugging\"},\n    \"lead-research-assistant\": {\"category\": \"business_marketing\", \"purpose\": \"Lead qualification\"},\n    \"linear-automation\": {\"category\": \"app_automation\", \"subcategory\": \"project_management\"},\n    \"linkedin-automation\": {\"category\": \"app_automation\", \"subcategory\": \"social_media\"},\n    \"mailchimp-automation\": {\"category\": \"app_automation\", \"subcategory\": \"email\"},\n    \"make-automation\": {\"category\": \"app_automation\", \"subcategory\": \"automation_platforms\"},\n    \"mcp-builder\": {\"category\": \"development\", \"purpose\": \"MCP server creation\"},\n    \"meeting-insights-analyzer\": {\"category\": \"communication_writing\", \"purpose\": \"Meeting analysis\"},\n    \"microsoft-teams-automation\": {\"category\": \"app_automation\", \"subcategory\": \"communication\"},\n    \"miro-automation\": {\"category\": \"app_automation\", \"subcategory\": \"design_collab\"},\n    \"mixpanel-automation\": {\"category\": \"app_automation\", \"subcategory\": \"analytics\"},\n    \"monday-automation\": {\"category\": \"app_automation\", \"subcategory\": \"project_management\"},\n    \"notion-automation\": {\"category\": \"app_automation\", \"subcategory\": \"project_management\"},\n    \"one-drive-automation\": {\"category\": \"app_automation\", \"subcategory\": \"storage\"},\n    \"opencode-orchestrator\": {\"category\": \"development\", \"purpose\": \"Autonomous coding\"},\n    \"outlook-automation\": {\"category\": \"app_automation\", \"subcategory\": \"email\"},\n    \"outlook-calendar-automation\": {\"category\": \"app_automation\", \"subcategory\": \"calendar\"},\n    \"pagerduty-automation\": {\"category\": \"app_automation\", \"subcategory\": \"devops\"},\n    \"pipedrive-automation\": {\"category\": \"app_automation\", \"subcategory\": \"crm_sales\"},\n    \"playwright-design-extractor\": {\"category\": \"development\", \"purpose\": \"Design system extraction\"},\n    \"posthog-automation\": {\"category\": \"app_automation\", \"subcategory\": \"analytics\"},\n    \"postmark-automation\": {\"category\": \"app_automation\", \"subcategory\": \"email\"},\n    \"raffle-winner-picker\": {\"category\": \"productivity\", \"purpose\": \"Random winner selection\"},\n    \"reddit-automation\": {\"category\": \"app_automation\", \"subcategory\": \"social_media\"},\n    \"render-automation\": {\"category\": \"app_automation\", \"subcategory\": \"devops\"},\n    \"salesforce-automation\": {\"category\": \"app_automation\", \"subcategory\": \"crm_sales\"},\n    \"segment-automation\": {\"category\": \"app_automation\", \"subcategory\": \"analytics\"},\n    \"sendgrid-automation\": {\"category\": \"app_automation\", \"subcategory\": \"email\"},\n    \"sentry-automation\": {\"category\": \"app_automation\", \"subcategory\": \"devops\"},\n    \"shopify-automation\": {\"category\": \"app_automation\", \"subcategory\": \"ecommerce\"},\n    \"skill-creator\": {\"category\": \"meta_utility\", \"purpose\": \"Create new skills\"},\n    \"skill-share\": {\"category\": \"development\", \"purpose\": \"Share skills\"},\n    \"slack\": {\"category\": \"messaging\", \"purpose\": \"Slack integration\"},\n    \"slack-automation\": {\"category\": \"app_automation\", \"subcategory\": \"communication\"},\n    \"slack-gif-creator\": {\"category\": \"creative_media\", \"purpose\": \"Slack GIFs\"},\n    \"square-automation\": {\"category\": \"app_automation\", \"subcategory\": \"ecommerce\"},\n    \"stripe-automation\": {\"category\": \"app_automation\", \"subcategory\": \"ecommerce\"},\n    \"supabase-automation\": {\"category\": \"app_automation\", \"subcategory\": \"devops\"},\n    \"tailored-resume-generator\": {\"category\": \"productivity\", \"purpose\": \"Job-specific resumes\"},\n    \"telegram-automation\": {\"category\": \"app_automation\", \"subcategory\": \"communication\"},\n    \"template-skill\": {\"category\": \"meta_utility\", \"purpose\": \"Skill template\"},\n    \"theme-factory\": {\"category\": \"creative_media\", \"purpose\": \"Theme styling\"},\n    \"tiktok-automation\": {\"category\": \"app_automation\", \"subcategory\": \"social_media\"},\n    \"todoist-automation\": {\"category\": \"app_automation\", \"subcategory\": \"project_management\"},\n    \"trello-automation\": {\"category\": \"app_automation\", \"subcategory\": \"project_management\"},\n    \"twitter-algorithm-optimizer\": {\"category\": \"business_marketing\", \"purpose\": \"Tweet optimization\"},\n    \"twitter-automation\": {\"category\": \"app_automation\", \"subcategory\": \"social_media\"},\n    \"vercel-automation\": {\"category\": \"app_automation\", \"subcategory\": \"devops\"},\n    \"video-downloader\": {\"category\": \"creative_media\", \"purpose\": \"YouTube downloader\"},\n    \"webapp-testing\": {\"category\": \"development\", \"purpose\": \"Playwright testing\"},\n    \"webflow-automation\": {\"category\": \"app_automation\", \"subcategory\": \"design_collab\"},\n    \"whatsapp-automation\": {\"category\": \"app_automation\", \"subcategory\": \"communication\"},\n    \"wrike-automation\": {\"category\": \"app_automation\", \"subcategory\": \"project_management\"},\n    \"yahoo-finance\": {\"category\": \"finance\", \"purpose\": \"Stock data\"},\n    \"youtube-automation\": {\"category\": \"app_automation\", \"subcategory\": \"social_media\"},\n    \"zendesk-automation\": {\"category\": \"app_automation\", \"subcategory\": \"support\"},\n    \"zoho-crm-automation\": {\"category\": \"app_automation\", \"subcategory\": \"crm_sales\"},\n    \"zoom-automation\": {\"category\": \"app_automation\", \"subcategory\": \"calendar\"}\n  },\n  \"use_case_keywords\": {\n    \"send_email\": [\"gmail-automation\", \"outlook-automation\", \"sendgrid-automation\", \"postmark-automation\", \"brevo-automation\"],\n    \"create_issue\": [\"github-automation\", \"gitlab-automation\", \"jira-automation\", \"linear-automation\"],\n    \"post_message\": [\"slack-automation\", \"discord-automation\", \"telegram-automation\", \"whatsapp-automation\", \"microsoft-teams-automation\"],\n    \"manage_tasks\": [\"notion-automation\", \"asana-automation\", \"trello-automation\", \"clickup-automation\", \"monday-automation\", \"todoist-automation\"],\n    \"database\": [\"airtable-automation\", \"supabase-automation\", \"googlesheets-automation\", \"coda-automation\"],\n    \"payments\": [\"stripe-automation\", \"square-automation\", \"shopify-automation\"],\n    \"calendar\": [\"google-calendar-automation\", \"outlook-calendar-automation\", \"calendly-automation\", \"cal-com-automation\"],\n    \"file_storage\": [\"google-drive-automation\", \"dropbox-automation\", \"box-automation\", \"one-drive-automation\"],\n    \"crm\": [\"hubspot-automation\", \"salesforce-automation\", \"pipedrive-automation\", \"close-automation\", \"zoho-crm-automation\"],\n    \"social_media\": [\"twitter-automation\", \"linkedin-automation\", \"instagram-automation\", \"tiktok-automation\", \"reddit-automation\", \"youtube-automation\"],\n    \"analytics\": [\"google-analytics-automation\", \"mixpanel-automation\", \"amplitude-automation\", \"posthog-automation\", \"segment-automation\"],\n    \"devops_ci\": [\"github-automation\", \"gitlab-automation\", \"circleci-automation\", \"vercel-automation\", \"render-automation\"],\n    \"design\": [\"figma-automation\", \"canva-automation\", \"miro-automation\", \"webflow-automation\"],\n    \"support_tickets\": [\"zendesk-automation\", \"freshdesk-automation\", \"freshservice-automation\", \"intercom-automation\", \"helpdesk-automation\"],\n    \"coding\": [\"opencode-orchestrator\", \"mcp-builder\", \"artifacts-builder\", \"webapp-testing\", \"langsmith-fetch\"],\n    \"content\": [\"content-research-writer\", \"changelog-generator\", \"meeting-insights-analyzer\"],\n    \"visual\": [\"canvas-design\", \"image-enhancer\", \"theme-factory\", \"slack-gif-creator\", \"video-downloader\"],\n    \"business\": [\"lead-research-assistant\", \"competitive-ads-extractor\", \"twitter-algorithm-optimizer\"],\n    \"organization\": [\"file-organizer\", \"invoice-organizer\"],\n    \"skill_meta\": [\"skill-creator\", \"connect\", \"connect-apps\"]\n  }\n}\n"}}],"api":"openai-completions","provider":"openrouter","model":"openrouter/pony-alpha","usage":{"input":32687,"output":5582,"cacheRead":3840,"cacheWrite":0,"totalTokens":42109,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1770692796557}}
