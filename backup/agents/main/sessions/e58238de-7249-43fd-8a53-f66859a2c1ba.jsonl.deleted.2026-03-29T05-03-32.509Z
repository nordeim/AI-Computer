{"type":"message","id":"99ce66e1","parentId":"ed3be62e","timestamp":"2026-03-05T13:28:22.544Z","message":{"role":"toolResult","toolCallId":"   functions.read:22","toolName":"read","content":[{"type":"text","text":"#!/bin/bash\n#\n# anchor-v2.sh - Enhanced Context Anchor with Full QMD Integration\n# Version: 2.0.0\n#\n# Recover context after compaction by scanning memory files and generating\n# a comprehensive \"here's where you are\" briefing with semantic enhancement.\n#\n# Usage:\n#   ./anchor-v2.sh                    # Full briefing\n#   ./anchor-v2.sh --quick            # Fast mode (skip QMD)\n#   ./anchor-v2.sh --semantic         # Enable semantic search\n#   ./anchor-v2.sh --task             # Show only current task\n#   ./anchor-v2.sh --active           # Show only active files\n#   ./anchor-v2.sh --decisions        # Show only decisions\n#   ./anchor-v2.sh --loops            # Show only open loops\n#   ./anchor-v2.sh --pending          # Filter: pending tasks\n#   ./anchor-v2.sh --blocked          # Filter: blocked tasks\n#   ./anchor-v2.sh --save             # Save snapshot to context/snapshots/\n#   ./anchor-v2.sh --days N           # Scan N days back (default: 3)\n\nset -euo pipefail\n\n# ─────────────────────────────────────────────────────────────────────────────\n# Configuration\n# ─────────────────────────────────────────────────────────────────────────────\n\nWORKSPACE=\"${WORKSPACE:-$(cd \"$(dirname \"$0\")/../../..\" && pwd)}\"\nMEMORY_DIR=\"$WORKSPACE/memory\"\nCONTEXT_DIR=\"$WORKSPACE/context/active\"\nSNAPSHOT_DIR=\"$WORKSPACE/context/snapshots\"\n\n# Defaults\nDAYS_BACK=\"${DAYS_BACK:-3}\"\nUSE_SEMANTIC=false\nSEMANTIC_DEPTH=5\nQUICK_MODE=false\nSAVE_SNAPSHOT=false\n\n# State filters\nFILTER_DECIDED=false\nFILTER_PENDING=false\nFILTER_BLOCKED=false\n\n# Output modes\nSHOW_ALL=true\nSHOW_TASK=false\nSHOW_ACTIVE=false\nSHOW_DECISIONS=false\nSHOW_LOOPS=false\n\n# ─────────────────────────────────────────────────────────────────────────────\n# Colors & Formatting\n# ─────────────────────────────────────────────────────────────────────────────\n\nif [ -t 1 ]; then\n    BOLD='\\033[1m'; DIM='\\033[2m'; RESET='\\033[0m'\n    BLUE='\\033[34m'; GREEN='\\033[32m'; YELLOW='\\033[33m'\n    CYAN='\\033[36m'; MAGENTA='\\033[35m'; RED='\\033[31m'\nelse\n    BOLD=''; DIM=''; RESET=''; BLUE=''; GREEN=''; YELLOW=''; CYAN=''; MAGENTA=''; RED=''\nfi\n\n# ─────────────────────────────────────────────────────────────────────────────\n# Helper Functions\n# ─────────────────────────────────────────────────────────────────────────────\n\nheader() {\n    echo -e \"${BOLD}${BLUE}$1${RESET}\"\n    echo -e \"${DIM}$(printf '%.0s─' {1..60})${RESET}\"\n}\n\nsection() {\n    echo \"\"\n    echo -e \"${BOLD}${CYAN}$1${RESET}\"\n    echo -e \"${DIM}$(printf '%.0s─' {1..60})${RESET}\"\n}\n\nrelative_time() {\n    local file=\"$1\"\n    local now=$(date +%s)\n    local mod\n    if [[ \"$OSTYPE\" == \"darwin\"* ]]; then\n        mod=$(stat -f %m \"$file\" 2>/dev/null || echo 0)\n    else\n        mod=$(stat -c %Y \"$file\" 2>/dev/null || echo 0)\n    fi\n    local diff=$((now - mod))\n    \n    if [ $diff -lt 60 ]; then echo \"just now\"\n    elif [ $diff -lt 3600 ]; then echo \"$((diff / 60))m ago\"\n    elif [ $diff -lt 86400 ]; then echo \"$((diff / 3600))h ago\"\n    else echo \"$((diff / 86400))d ago\"\n    fi\n}\n\nextract_date_from_path() {\n    local filepath=\"$1\"\n    if [[ \"$filepath\" =~ /daily/([0-9]{4})/([0-9]{2})/([0-9]{2})\\.md$ ]]; then\n        echo \"${BASH_REMATCH[1]}-${BASH_REMATCH[2]}-${BASH_REMATCH[3]}\"\n    elif [[ \"$(basename \"$filepath\" .md)\" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then\n        basename \"$filepath\" .md\n    else\n        basename \"$filepath\" .md\n    fi\n}\n\nqmd_available() {\n    command -v qmd >/dev/null 2>&1 && [ \"$QUICK_MODE\" = false ]\n}\n\n# ─────────────────────────────────────────────────────────────────────────────\n# QMD Semantic Expansion\n# ─────────────────────────────────────────────────────────────────────────────\n\nsemantic_expand() {\n    local query=\"$1\"\n    local depth=\"${2:-3}\"\n    local collection=\"${3:-daily}\"\n    \n    if ! qmd_available || [ \"$USE_SEMANTIC\" = false ]; then return 0; fi\n    \n    qmd query \"$query\" -c \"$collection\" --limit \"$depth\" 2>/dev/null | \\\n        grep -v \"^Warning:\" | grep -v \"^Collection:\" | grep -v \"^Query:\" | \\\n        head -$((depth * 2)) | grep -E \"[a-zA-Z]\" | head -$depth 2>/dev/null || true\n}\n\nsemantic_related_tasks() {\n    local task_text=\"$1\"\n    if ! qmd_available || [ \"$USE_SEMANTIC\" = false ]; then return 0; fi\n    \n    echo -e \"${DIM}Related context via QMD semantic search:${RESET}\"\n    semantic_expand \"$task_text\" 3 \"daily\" | sed 's/^/  └─ /' | sed \"s/^/${DIM}/;s/$/${RESET}/\" || true\n}\n\n# ─────────────────────────────────────────────────────────────────────────────\n# File Discovery\n# ─────────────────────────────────────────────────────────────────────────────\n\nget_daily_files() {\n    local files=()\n    local seen_dates=()\n    \n    for i in $(seq 0 $((DAYS_BACK - 1))); do\n        local year month day\n        if [[ \"$OSTYPE\" == \"darwin\"* ]]; then\n            year=$(date -v-${i}d +%Y); month=$(date -v-${i}d +%m); day=$(date -v-${i}d +%d)\n        else\n            year=$(date -d \"-$i days\" +%Y); month=$(date -d \"-$i days\" +%m); day=$(date -d \"-$i days\" +%d)\n        fi\n        \n        [[ \" ${seen_dates[@]:-} \" =~ \" ${year}-${month}-${day} \" ]] && continue\n        seen_dates+=(\"${year}-${month}-${day}\")\n        \n        local qmd_file=\"$MEMORY_DIR/daily/$year/$month/$day.md\"\n        if [ -f \"$qmd_file\" ]; then files+=(\"$qmd_file\"); continue; fi\n        \n        local flat_file=\"$MEMORY_DIR/${year}-${month}-${day}.md\"\n        if [ -f \"$flat_file\" ]; then files+=(\"$flat_file\"); fi\n    done\n    \n    printf '%s\\n' \"${files[@]:-}\"\n}\n\n# ─────────────────────────────────────────────────────────────────────────────\n# Output Sections\n# ─────────────────────────────────────────────────────────────────────────────\n\nshow_current_task() {\n    section \"📋 CURRENT TASK\"\n    local task_file=\"$MEMORY_DIR/current-task.md\"\n    \n    if [ -f \"$task_file\" ]; then\n        echo -e \"${DIM}($(relative_time \"$task_file\"))${RESET}\"\n        echo \"\"; cat \"$task_file\"\n        if [ \"$USE_SEMANTIC\" = true ]; then\n            echo \"\"; semantic_related_tasks \"$(head -5 \"$task_file\")\"\n        fi\n    else\n        echo -e \"${DIM}No current task set (create memory/current-task.md)${RESET}\"\n    fi\n    echo \"\"\n}\n\nshow_active_context() {\n    section \"📂 ACTIVE CONTEXT FILES\"\n    \n    if [ ! -d \"$CONTEXT_DIR\" ] || [ -z \"$(ls -A \"$CONTEXT_DIR\" 2>/dev/null)\" ]; then\n        echo -e \"${DIM}No active context files${RESET}\"\n        echo \"\"; return\n    fi\n    \n    local found=false\n    for file in \"$CONTEXT_DIR\"/*.md; do\n        [ -e \"$file\" ] || continue; found=true\n        local name=$(basename \"$file\") age=$(relative_time \"$file\")\n        local preview=$(head -n 5 \"$file\" 2>/dev/null | grep -v '^#' | grep -v '^$' | head -n 1)\n        echo -e \"${GREEN}• ${name}${RESET} ${DIM}(${age})${RESET}\"\n        [ -n \"$preview\" ] && echo -e \"  ${DIM}└─ ${preview:0:65}...${RESET}\"\n    done\n    \n    [ \"$found\" = false ] && echo -e \"${DIM}No active context files${RESET}\"\n    echo \"\"\n}\n\nshow_decisions() {\n    section \"🎯 RECENT DECISIONS (last $DAYS_BACK days)\"\n    local files=($(get_daily_files)) found=false\n    \n    for file in \"${files[@]}\"; do\n        [ -f \"$file\" ] || continue\n        local date=$(extract_date_from_path \"$file\")\n        grep -n -i -E \"(^|\\s)(decision:|decided:|chose:|picked:|went with|✅.*completed|✅.*done)\" \"$file\" 2>/dev/null | \\\n        while IFS= read -r line; do\n            found=true\n            local content=$(echo \"$line\" | sed 's/^[0-9]*://; s/^[ -]*//')\n            echo -e \"${CYAN}[$date]${RESET} $content\"\n        done\n    done\n    \n    [ \"$found\" = false ] && echo -e \"${DIM}No explicit decisions found${RESET}\"\n    echo \"\"\n}\n\nshow_loops() {\n"}],"isError":false,"timestamp":1772717302538}}
