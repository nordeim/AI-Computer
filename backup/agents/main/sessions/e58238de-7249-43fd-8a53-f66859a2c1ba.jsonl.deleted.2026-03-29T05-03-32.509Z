──────────────────────────────────────────────────────────────────\n# Colors & Formatting\n# ─────────────────────────────────────────────────────────────────────────────\n\nif [ -t 1 ]; then\n    BOLD='\\033[1m'; DIM='\\033[2m'; RESET='\\033[0m'\n    BLUE='\\033[34m'; GREEN='\\033[32m'; YELLOW='\\033[33m'\n    CYAN='\\033[36m'; MAGENTA='\\033[35m'; RED='\\033[31m'\nelse\n    BOLD=''; DIM=''; RESET=''; BLUE=''; GREEN=''; YELLOW=''; CYAN=''; MAGENTA=''; RED=''\nfi\n\n# ─────────────────────────────────────────────────────────────────────────────\n# Helper Functions\n# ─────────────────────────────────────────────────────────────────────────────\n\nheader() {\n    echo -e \"${BOLD}${BLUE}$1${RESET}\"\n    echo -e \"${DIM}$(printf '%.0s─' {1..60})${RESET}\"\n}\n\nsection() {\n    echo \"\"\n    echo -e \"${BOLD}${CYAN}$1${RESET}\"\n    echo -e \"${DIM}$(printf '%.0s─' {1..60})${RESET}\"\n}\n\nrelative_time() {\n    local file=\"$1\"\n    local now=$(date +%s)\n    local mod\n    if [[ \"$OSTYPE\" == \"darwin\"* ]]; then\n        mod=$(stat -f %m \"$file\" 2>/dev/null || echo 0)\n    else\n        mod=$(stat -c %Y \"$file\" 2>/dev/null || echo 0)\n    fi\n    local diff=$((now - mod))\n    \n    if [ $diff -lt 60 ]; then echo \"just now\"\n    elif [ $diff -lt 3600 ]; then echo \"$((diff / 60))m ago\"\n    elif [ $diff -lt 86400 ]; then echo \"$((diff / 3600))h ago\"\n    else echo \"$((diff / 86400))d ago\"\n    fi\n}\n\nextract_date_from_path() {\n    local filepath=\"$1\"\n    if [[ \"$filepath\" =~ /daily/([0-9]{4})/([0-9]{2})/([0-9]{2})\\.md$ ]]; then\n        echo \"${BASH_REMATCH[1]}-${BASH_REMATCH[2]}-${BASH_REMATCH[3]}\"\n    elif [[ \"$(basename \"$filepath\" .md)\" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then\n        basename \"$filepath\" .md\n    else\n        basename \"$filepath\" .md\n    fi\n}\n\nqmd_available() {\n    command -v qmd >/dev/null 2>&1 && [ \"$QUICK_MODE\" = false ]\n}\n\n# ─────────────────────────────────────────────────────────────────────────────\n# QMD Semantic Expansion\n# ─────────────────────────────────────────────────────────────────────────────\n\nsemantic_expand() {\n    local query=\"$1\"\n    local depth=\"${2:-3}\"\n    local collection=\"${3:-daily}\"\n    \n    if ! qmd_available || [ \"$USE_SEMANTIC\" = false ]; then\n        return 0\n    fi\n    \n    # Use hybrid query for best results (BM25 + vectors + rerank)\n    qmd query \"$query\" -c \"$collection\" --limit \"$depth\" 2>/dev/null | \\\n        grep -v \"^Warning:\" | \\\n        grep -v \"^Collection:\" | \\\n        grep -v \"^Query:\" | \\\n        head -$((depth * 2)) | \\\n        grep -E \"[a-zA-Z]\" | \\\n        head -$depth 2>/dev/null || true\n}\n\nsemantic_related_tasks() {\n    local task_text=\"$1\"\n    if ! qmd_available || [ \"$USE_SEMANTIC\" = false ]; then\n        return 0\n    fi\n    \n    echo -e \"${DIM}Related context via QMD semantic search:${RESET}\"\n    semantic_expand \"$task_text\" 3 \"daily\" | sed 's/^/  └─ /' | sed \"s/^/${DIM}/;s/$/${RESET}/\" || true\n}\n\n# ─────────────────────────────────────────────────────────────────────────────\n# File Discovery\n# ─────────────────────────────────────────────────────────────────────────────\n\nget_daily_files() {\n    local files=()\n    local seen_dates=()\n    \n    for i in $(seq 0 $((DAYS_BACK - 1))); do\n        local year month day\n        if [[ \"$OSTYPE\" == \"darwin\"* ]]; then\n            year=$(date -v-${i}d +%Y)\n            month=$(date -v-${i}d +%m)\n            day=$(date -v-${i}d +%d)\n        else\n            year=$(date -d \"-$i days\" +%Y)\n            month=$(date -d \"-$i days\" +%m)\n            day=$(date -d \"-$i days\" +%d)\n        fi\n        \n        # Skip if already seen\n        [[ \" ${seen_dates[@]:-} \" =~ \" ${year}-${month}-${day} \" ]] && continue\n        seen_dates+=(\"${year}-${month}-${day}\")\n        \n        # QMD hierarchical path (preferred)\n        local qmd_file=\"$MEMORY_DIR/daily/$year/$month/$day.md\"\n        if [ -f \"$qmd_file\" ]; then\n            files+=(\"$qmd_file\")\n            continue\n        fi\n        \n        # Flat path (legacy fallback)\n        local flat_file=\"$MEMORY_DIR/${year}-${month}-${day}.md\"\n        if [ -f \"$flat_file\" ]; then\n            files+=(\"$flat_file\")\n        fi\n    done\n    \n    printf '%s\\n' \"${files[@]:-}\"\n}\n\n# ─────────────────────────────────────────────────────────────────────────────\n# Output Sections\n# ─────────────────────────────────────────────────────────────────────────────\n\nshow_current_task() {\n    section \"📋 CURRENT TASK\"\n    local task_file=\"$MEMORY_DIR/current-task.md\"\n    \n    if [ -f \"$task_file\" ]; then\n        echo -e \"${DIM}($(relative_time \"$task_file\"))${RESET}\"\n        echo \"\"\n        cat \"$task_file\"\n        \n        if [ \"$USE_SEMANTIC\" = true ]; then\n            echo \"\"\n            semantic_related_tasks \"$(head -5 \"$task_file\")\"\n        fi\n    else\n        echo -e \"${DIM}No current task set (create memory/current-task.md)${RESET}\"\n    fi\n    echo \"\"\n}\n\nshow_active_context() {\n    section \"📂 ACTIVE CONTEXT FILES\"\n    \n    if [ ! -d \"$CONTEXT_DIR\" ] || [ -z \"$(ls -A \"$CONTEXT_DIR\" 2>/dev/null)\" ]; then\n        echo -e \"${DIM}No active context files${RESET}\"\n        echo \"\"\n        return\n    fi\n    \n    local found=false\n    for file in \"$CONTEXT_DIR\"/*.md; do\n        [ -e \"$file\" ] || continue\n        found=true\n        local name=$(basename \"$file\")\n        local age=$(relative_time \"$file\")\n        local preview=$(head -n 5 \"$file\" 2>/dev/null | grep -v '^#' | grep -v '^$' | head -n 1)\n        \n        echo -e \"${GREEN}• ${name}${RESET} ${DIM}(${age})${RESET}\"\n        [ -n \"$preview\" ] && echo -e \"  ${DIM}└─ ${preview:0:65}...${RESET}\"\n    done\n    \n    [ \"$found\" = false ] && echo -e \"${DIM}No active context files${RESET}\"\n    echo \"\"\n}\n\nshow_active_tasks_filtered() {\n    section \"📂 ACTIVE CONTEXT FILES\"\n    \n    if [ ! -d \"$CONTEXT_DIR\" ] || [ -z \"$(ls -A \"$CONTEXT_DIR\" 2>/dev/null)\" ]; then\n        echo -e \"${DIM}No active context files${RESET}\"\n        echo \"\"\n        return\n    fi\n    \n    local found=false\n    for file in \"$CONTEXT_DIR\"/*.md; do\n        [ -e \"$file\" ] || continue\n        \n        local content=$(cat \"$file\" 2>/dev/null)\n        local match=false\n        \n        if [ \"$FILTER_DECIDED\" = true ] && echo \"$content\" | grep -qiE \"(decided|decision:|✅.*done|status.*complete)\"; then\n            match=true\n        fi\n        if [ \"$FILTER_PENDING\" = true ] && echo \"$content\" | grep"}}],"api":"openai-completions","provider":"nvidia","model":"moonshotai/kimi-k2.5","usage":{"input":34099,"output":2467,"cacheRead":0,"cacheWrite":0,"totalTokens":36566,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772702612834}}
