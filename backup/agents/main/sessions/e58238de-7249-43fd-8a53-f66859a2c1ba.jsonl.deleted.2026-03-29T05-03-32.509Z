{"type":"message","id":"4a659030","parentId":"7d2082ec","timestamp":"2026-03-04T23:32:41.440Z","message":{"role":"toolResult","toolCallId":"     functions.read:11","toolName":"read","content":[{"type":"text","text":"#!/bin/bash\n#\n# context-anchor: Recover context after compaction\n# Scans memory files and generates a \"here's where you are\" briefing\n# Supports QMD hierarchical (daily/YYYY/MM/DD.md) and flat (YYYY-MM-DD.md)\n# NEW: QMD semantic integration for enhanced context recovery\n#\n\nset -e\n\nWORKSPACE=\"${WORKSPACE:-$(cd \"$(dirname \"$0\")/../../..\" && pwd)}\"\nMEMORY_DIR=\"$WORKSPACE/memory\"\nCONTEXT_DIR=\"$WORKSPACE/context/active\"\nDAYS_BACK=\"${DAYS_BACK:-2}\"\nUSE_SEMANTIC=false\nSEMANTIC_DEPTH=3\nQUICK_MODE=false\n\nif [ -t 1 ]; then\n    BOLD='\\033[1m'; DIM='\\033[2m'; RESET='\\033[0m'\n    BLUE='\\033[34m'; GREEN='\\033[32m'; YELLOW='\\033[33m'\n    CYAN='\\033[36m'\nelse\n    BOLD=''; DIM=''; RESET=''; BLUE=''; GREEN=''; YELLOW=''; CYAN=''\nfi\n\nSHOW_ALL=true\n\nwhile [[ $# -gt 0 ]]; do\n    case $1 in\n        --quick) QUICK_MODE=true; shift ;;\n        --semantic) USE_SEMANTIC=true; shift ;;\n        --task|--active|--decisions|--loops) SHOW_ALL=false; shift ;;\n        --days) DAYS_BACK=\"$2\"; shift 2 ;;\n        --help) echo \"context-anchor: Recover context after compaction. Use --quick for fast mode, --semantic for QMD integration.\"; exit 0 ;;\n        *) echo \"Unknown: $1\"; exit 1 ;;\n    esac\ndone\n\necho \"\"\necho \"═══════════════════════════════════════════════════════════\"\necho \" CONTEXT ANCHOR — Where You Left Off\"\necho \"═══════════════════════════════════════════════════════════\"\necho \"\"\n\n# Scan recent daily files\nfor i in $(seq 0 $((DAYS_BACK - 1))); do\n    local year=$(date -d \"-$i days\" +%Y)\n    local month=$(date -d \"-$i days\" +%m)\n    local day=$(date -d \"-$i days\" +%d)\n    local file=\"$MEMORY_DIR/daily/$year/$month/$day.md\"\n    [ -f \"$file\" ] && echo \"[Daily] $year-$month-$day: Found\"\ndone\n\n# QMD integration\necho \"\"\nif command -v qmd >/dev/null 2>&1 && [ \"$QUICK_MODE\" = false ] && [ \"$USE_SEMANTIC\" = true ]; then\n    echo \"QMD Status: Available (semantic expansion enabled)\"\n    qmd status 2>/dev/null | head -5 || echo \"QMD ready\"\nelse\n    echo \"QMD Status: ${QUICK_MODE:+Quick mode (skipped), ${USE_SEMANTIC:+Semantic disabled}, system ready}\"\nfi\n\necho \"\"\necho \"═══════════════════════════════════════════════════════════\"\n"}],"isError":false,"timestamp":1772667161437}}
