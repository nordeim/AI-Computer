n  \"bodyFont\": \"\\\"DM Sans\\\", sans-serif\",\n  \"h1Font\": \"\\\"DM Sans\\\", sans-serif\",\n  \"h1Size\": \"76.8px\",\n  \"h1Weight\": \"700\",\n  \"h1Color\": \"rgb(17, 24, 39)\",\n  \"h1LineHeight\": \"81.408px\",\n  \"h2Font\": \"\\\"DM Sans\\\", sans-serif\",\n  \"h2Size\": \"40px\",\n  \"h2Color\": \"rgb(17, 24, 39)\",\n  \"btnBg\": \"rgba(0, 0, 0, 0)\",\n  \"btnColor\": \"rgb(17, 24, 39)\",\n  \"btnRadius\": \"0px\",\n  \"btnPadding\": \"4px 0px\",\n  \"btnFont\": \"\\\"DM Sans\\\", sans-serif\",\n  \"navBg\": \"rgb(255, 255, 255)\",\n  \"navColor\": \"rgb(55, 65, 81)\",\n  \"backgrounds\": [\n    \"rgb(255, 255, 255)\",\n    \"rgb(242, 122, 26)\",\n    \"rgba(242, 122, 26, 0.08)\",\n    \"rgb(248, 249, 250)\",\n    \"rgb(236, 253, 245)\"\n  ],\n  \"textColors\": [\n    \"rgb(17, 24, 39)\",\n    \"rgb(107, 114, 128)\",\n    \"rgb(255, 255, 255)\",\n    \"rgb(0, 0, 0)\",\n    \"rgb(55, 65, 81)\",\n    \"rgb(242, 122, 26)\",\n    \"rgb(43, 188, 179)\",\n    \"rgb(59, 130, 246)\",\n    \"rgb(124, 58, 237)\",\n    \"rgb(5, 150, 105)\"\n  ]\n}"},"isError":false,"timestamp":1773496052688}}
