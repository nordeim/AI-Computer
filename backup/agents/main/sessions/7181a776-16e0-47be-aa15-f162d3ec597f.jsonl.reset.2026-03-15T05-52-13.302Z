xt \" to provide alternative context management strategies without modifying core compaction logic. Zero behavior change when no context engine plugin is configured. (\"\n              - InlineTextBox \" to provide alternative context management strategies without modifying core \"\n              - InlineTextBox \"compaction logic. Zero behavior change when no context engine plugin is configured. (\"\n            - link \"#22201\" [ref=e1313]\n              - StaticText \"#22201\"\n                - InlineTextBox \"#22201\"\n            - StaticText \") thanks \"\n              - InlineTextBox \") thanks \"\n            - link \"@jalehman\" [ref=e1314]\n              - StaticText \"@jalehman\"\n                - InlineTextBox \"@jalehman\"\n            - StaticText \".\"\n              - InlineTextBox \".\"\n          - listitem [level=1]\n            - ListMarker \"• \"\n            - StaticText \"ACP/persistent channel bindings: add durable Discord channel and Telegram topic binding storage, routing resolution, and CLI/docs support so ACP thread targets survive restarts and can be managed consistently. (\"\n              - InlineTextBox \"ACP/persistent channel bindings: add durable Discord channel and Telegram topic binding storage, routing \"\n              - InlineTextBox \"resolution, and CLI/docs support so ACP thread targets survive restarts and can be managed consistently. \"\n              - InlineTextBox \"(\"\n            - link \"#34873\" [ref=e1315]\n              - StaticText \"#34873\"\n                - InlineTextBox \"#34873\"\n            - StaticText \") Thanks \"\n              - InlineTextBox \") Thanks \"\n            - link \"@dutifulbob\" [ref=e1316]\n              - StaticText \"@dutifulbob\"\n                - InlineTextBox \"@dutifulbob\"\n            - StaticText \".\"\n              - InlineTextBox \".\"\n          - listitem [level=1]\n            - ListMarker \"• \"\n            - StaticText \"Telegram/ACP topic bindings: accept Telegram Mac Unicode dash option prefixes in \"\n              - InlineTextBox \"Telegram/ACP topic bindings: accept Telegram Mac Unicode dash option prefixes in \"\n            - code\n              - StaticText \"/acp spawn\"\n                - InlineTextBox \"/acp spawn\"\n            - StaticText \", support Telegram topic thread binding (\"\n              - InlineTextBox \", support \"\n              - InlineTextBox \"Telegram topic thread binding (\"\n            - code\n              - StaticText \"--thread here|auto\"\n                - InlineTextBox \"--thread here|auto\"\n            - StaticText \"), route bound-topic follow-ups to ACP sessions, add actionable Telegram approval buttons with prefixed approval-id resolution, and pin successful bind confirmations in-topic. (\"\n              - InlineTextBox \"), route bound-topic follow-ups to ACP sessions, add \"\n              - InlineTextBox \"actionable Telegram approval buttons with prefixed approval-id resolution, and pin successful bind \"\n              - InlineTextBox \"confirmations in-topic. (\"\n            - link \"#36683\" [ref=e1317]\n              - StaticText \"#36683\"\n                - InlineTextBox \"#36683\"\n            - StaticText \") Thanks \"\n              - InlineTextBox \") Thanks \"\n            - link \"@huntharo\" [ref=e1318]\n              - StaticText \"@huntharo\"\n                - InlineTextBox \"@huntharo\"\n            - StaticText \".\"\n              - InlineTextBox \".\"\n          - listitem [level=1]\n            - ListMarker \"• \"\n            - StaticText \"Telegram/topic agent routing: support per-topic \"\n              - InlineTextBox \"Telegram/topic agent routing: support per-topic \"\n            - code\n              - StaticText \"agentId\"\n                - InlineTextBox \"agentId\"\n            - StaticText \" overrides in forum groups and DM topics so topics can route to dedicated agents with isolated sessions. (\"\n              - InlineTextBox \" overr